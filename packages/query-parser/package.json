{
  "name": "@zipbul/query-parser",
  "version": "0.0.1",
  "description": "High-performance, RFC 3986 compliant query string parser with strict security controls",
  "license": "MIT",
  "author": "Junhyung Park (https://github.com/parkrevil)",
  "repository": {
    "type": "git",
    "url": "https://github.com/zipbul/toolkit",
    "directory": "packages/query-parser"
  },
  "bugs": "https://github.com/zipbul/toolkit/issues",
  "homepage": "https://github.com/zipbul/toolkit/tree/main/packages/query-parser#readme",
  "keywords": [
    "query-string",
    "query-parser",
    "url",
    "http",
    "bun",
    "typescript",
    "zipbul"
  ],
  "engines": {
    "bun": ">=1.0.0"
  },
  "type": "module",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun build index.ts --outdir dist --target bun --format esm --packages external --production --sourcemap=linked && tsc -p tsconfig.build.json",
    "test": "bun test",
    "coverage": "bun test --coverage"
  },
  "dependencies": {
    "@zipbul/result": "workspace:*"
  },
  "devDependencies": {}
}
