{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "rootDir": ".",
    "experimentalDecorators": true,
    "paths": {
      "@zipbul/result": ["../result/index.ts"],
      "@zipbul/baker": ["./index.ts"],
      "@zipbul/baker/symbols": ["./src/symbols.ts"],
      "@zipbul/baker/decorators": ["./src/decorators/index.ts"],
      "@zipbul/baker/stubs": ["./src/stubs/index.ts"],
      "@zipbul/baker/rules": ["./src/rules/index.ts"],
      "@zipbul/baker/testing": ["./testing.ts"]
    }
  },
  "include": ["./**/*.ts"]
}
